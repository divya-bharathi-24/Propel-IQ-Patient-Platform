# .env.example — copy to .env and fill in real values before running docker compose up
# The .env file is listed in .gitignore and MUST NOT be committed to source control.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=propeliq
POSTGRES_PASSWORD=changeme
POSTGRES_DB=propeliq
# Used by the backend API; references the Docker service name "postgres" as host
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=propeliq;Username=propeliq;Password=changeme

# ── Redis ──────────────────────────────────────────────────────────────────────
# Set to true to connect to the local redis container (mirrors Upstash interface)
# Set to false and provide REDIS_CONNECTION_STRING for production Upstash TLS URL
REDIS_USE_LOCAL=true
REDIS_CONNECTION_STRING=redis:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HMAC-SHA256 (FR-005)
JWT_SECRET=change-me-to-a-32-character-minimum-secret-key!!
JWT_ISSUER=propeliq-api
JWT_AUDIENCE=propeliq-client
JWT_EXPIRY_MINUTES=60

# ── ASP.NET Core ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
