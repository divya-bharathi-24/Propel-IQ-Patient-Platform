{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Set via env var: DATABASE_URL (Railway) or ConnectionStrings__DefaultConnection
    "DefaultConnection": ""
  },
  "Redis": {
    "UseLocal": false,
    "LocalConnectionString": "redis:6379",
    // Set via env var: REDIS_URL (Railway)
    "ConnectionString": ""
  },
  "Jwt": {
    // Set via env var: JWT__SecretKey (Railway) — minimum 32-character random secret
    "SecretKey": "",
    // Set via env var: JWT__Issuer (Railway)
    "Issuer": "",
    // Set via env var: JWT__Audience (Railway)
    "Audience": "",
    "ExpiryMinutes": 60
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        // Certificate is supplied via env var KESTREL__CERTIFICATES__DEFAULT__PATH (Railway dev)
        // or the ASP.NET Core dev cert in local development (dotnet dev-certs https --trust).
        // Leave empty here; override via environment variables in production.
        "Url": "https://0.0.0.0:5001"
      }
    },
    // Connection limits for horizontal scaling with 100 concurrent users (NFR-010, EP-011/us_053/task_002).
    // These are documented here for visibility; the actual limits are set in ConfigureKestrel in Program.cs.
    // MaxConcurrentConnections: 200 (2× headroom for 100 concurrent users)
    // MaxRequestBodySize: 1 MB global (upload endpoints override with [RequestSizeLimit])
    "Limits": {
      "MaxConcurrentConnections": 200,
      "MaxRequestBodySize": 1048576
    }
  },
  // Document storage configuration (US_038, US_039, EP-011/us_053/task_002).
  // StoragePath: absolute or relative path to the directory where documents are stored.
  // Override via env var: DocumentStorage__StoragePath
  "DocumentStorage": {
    "StoragePath": "./document-storage"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowMinutes": 1
  },
  "SendGrid": {
    // Set via env var: SENDGRID__APIKEY (Railway)
    "ApiKey": "",
    // Set via env var: SENDGRID__FROMEMAIL (Railway)
    "FromEmail": "noreply@propeliq.app",
    // Set via env var: SENDGRID__FROMNAME (Railway)
    "FromName": "PropelIQ"
  },
  "Twilio": {
    // Set via env var: TWILIO__ACCOUNTSID (Railway)
    "AccountSid": "",
    // Set via env var: TWILIO__AUTHTOKEN (Railway)
    "AuthToken": "",
    // Set via env var: TWILIO__FROMNUMBER (Railway) — E.164 format, e.g. "+15551234567"
    "FromNumber": ""
  },
  // Base URL used to construct email verification links.
  // Set via env var: APPBASEURL (Railway)
  "AppBaseUrl": "https://propeliq.netlify.app",
  // Slot grid configuration for GET /api/appointments/slots (US_018, task_002).
  // Defines business hours and slot duration used to generate the full time-slot grid.
  // Override via env vars: SlotConfiguration__SlotDurationMinutes, etc.
  "SlotConfiguration": {
    "SlotDurationMinutes": 30,
    "BusinessHoursStart": "09:00",
    "BusinessHoursEnd": "17:00"
  },
  // AI intake configuration (EP-005/US_028, task_003).
  // API keys (OPENAI_API_KEY, AZURE_OPENAI_API_KEY) are sourced from environment variables only — NEVER stored here (OWASP A02).
  // Override individual settings via env vars using double-underscore notation: Ai__ModelDeploymentName, etc.
  "Ai": {
    "ModelDeploymentName": "gpt-4o",
    "MaxTokensPerRequest": 8000,
    "IntakePromptVersion": "v1",
    // Risk assessment prompt version (us_031, task_003, AIR-O03). Override via Ai__RiskAssessmentPromptVersion env var.
    "RiskAssessmentPromptVersion": "v1",
    "CircuitBreakerFailureThreshold": 3,
    "CircuitBreakerWindowSeconds": 300,
    "UseAzureOpenAI": false
  },
  // AI operational resilience controls (EP-010/us_050, AIR-O01, AIR-O02, AIR-O03).
  // Override individual settings via env vars: AiResilience__DefaultModelVersion, etc.
  "AiResilience": {
    // Fallback model version when Redis key ai:config:model_version is absent (AIR-O03).
    // Override via AiResilience__DefaultModelVersion env var.
    "DefaultModelVersion": "gpt-4o",
    // Maximum token budget enforced per request by TokenBudgetFilter (AIR-O01).
    "TokenBudgetLimit": 8000,
    // Number of consecutive failures before Redis circuit breaker trips (AIR-O02).
    "CircuitBreakerFailureThreshold": 3,
    // Sliding window (minutes) over which consecutive failures are counted (AIR-O02).
    "CircuitBreakerWindowMinutes": 5,
    // Number of most recent records used for p95 and token average computations (AIR-O04).
    "MetricsWindowSize": 500,
    // Allowed model versions for POST /api/admin/ai-config/model-version whitelist (AIR-O03, OWASP A03).
    // Empty array = whitelist disabled (development only). Populate for production.
    "AllowedModelVersions": [
      "gpt-4o",
      "gpt-4o-2024-08-06",
      "gpt-4o-2024-11-20",
      "gpt-4o-mini"
    ]
  },
  // AI safety content filter configuration (EP-010/us_049, task_001, AIR-S04).
  // BlockedKeywords: case-insensitive keyword blocklist checked against every AI response.
  // Add terms that indicate hallucinated prescriptions, harmful advice, or clinical recommendations.
  "AiSafety": {
    "BlockedKeywords": [
      "you should take",
      "i recommend",
      "i suggest",
      "increase dosage",
      "decrease dosage",
      "stop taking",
      "discontinue",
      "seek emergency",
      "call 911"
    ]
  },
  // Google Calendar OAuth 2.0 (EP-007/us_035, task_002).
  // Non-secret values only — GOOGLE_CLIENT_SECRET is sourced from environment variable only (OWASP A02).
  // Override individual settings via env vars: GoogleCalendar__ClientId, GoogleCalendar__RedirectUri, etc.
  "GoogleCalendar": {
    // Set via env var: GoogleCalendar__ClientId (or appsettings override)
    "ClientId": "",
    // Registered redirect URI in Google Cloud Console.
    // Set via env var: GoogleCalendar__RedirectUri
    "RedirectUri": "https://api.propeliq.app/api/calendar/google/callback",
    // Frontend base URL to redirect the patient after OAuth completes.
    // Set via env var: GoogleCalendar__FrontendConfirmationUrl
    "FrontendConfirmationUrl": "https://propeliq.netlify.app/appointments"
  },
  // ── Horizontal Scalability Contract (EP-011/us_053/task_002, NFR-016, AC-3) ──────────────
  // Documents the stateless backend contract for horizontal scaling without sticky sessions.
  // No code reads this section at runtime; it is a machine-readable operational policy record.
  "Scalability": {
    // Session tokens stored exclusively in Redis (Upstash) with 15-minute TTL (NFR-016).
    "SessionStore": "Redis",
    // All caches backed by Redis (Upstash); no in-process IMemoryCache for session/user state.
    "CacheStore": "Redis",
    // Stateless contract summary (NFR-016, AC-3).
    // IMemoryCache is only permitted for short-lived read-through caches (≤60s TTL) such as
    // model version and feature flags that are eventually consistent and not session-critical.
    "StatelessContract": "No in-process state. All session tokens in Redis (TTL 15min). All application state in PostgreSQL. IMemoryCache only for read-through caches with TTL ≤60s (model version, feature flags).",
    // Horizontal scaling instructions (NFR-016).
    "HorizontalScalingNotes": "Deploy additional instances with the same environment variables. No sticky sessions required. Redis Upstash is shared across all instances. EF Core Npgsql pool size=50 per instance (10× headroom at 100 RPS)."
  }
}
